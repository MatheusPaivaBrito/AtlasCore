# ------------------------------------
# APP
# ------------------------------------
APP_NAME=AtlasCore
ENVIRONMENT=development
APP_DEBUG=1
SERVICE_NAME=core_api

# ------------------------------------
# POSTGRES
# ------------------------------------
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=atlas_core

# ------------------------------------
# REDIS
# ------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# ------------------------------------
# CONNECTION URL OVERRIDES
# ------------------------------------
DATABASE_URL=
REDIS_URL=

# ------------------------------------
# API PORTS
# ------------------------------------
CORE_API_PORT=8000
AUTH_API_PORT=8001
EVENTING_API_PORT=8002
NOTIFICATION_API_PORT=8003
OBSERVABILITY_API_PORT=8004

# ------------------------------------
# FRONTEND ORIGINS
# ------------------------------------
FRONTEND_PUBLIC_URL=http://localhost:5173
FRONTEND_ADMIN_PUBLIC_URL=http://localhost:3000

# ------------------------------------
# PLATFORM DISCOVERY
# ------------------------------------
CORE_API_PUBLIC_URL=http://localhost:8000
AUTH_API_PUBLIC_URL=http://localhost:8001
EVENTING_API_PUBLIC_URL=http://localhost:8002
NOTIFICATION_API_PUBLIC_URL=http://localhost:8003
OBSERVABILITY_API_PUBLIC_URL=http://localhost:8004
CORE_API_INTERNAL_URL=http://localhost:8000
AUTH_API_INTERNAL_URL=http://localhost:8001
EVENTING_API_INTERNAL_URL=http://localhost:8002
NOTIFICATION_API_INTERNAL_URL=http://localhost:8003
OBSERVABILITY_API_INTERNAL_URL=http://localhost:8004
SERVICE_HEALTH_PATH=/health
SERVICE_DOCS_PATH=/docs
SERVICE_REDOC_PATH=/redoc
SERVICE_CHECK_TIMEOUT_SECONDS=0.2

# ------------------------------------
# CORS
# ------------------------------------
CORS_ALLOW_CREDENTIALS=1
CORE_API_CORS_ENABLED=1
CORE_API_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_API_CORS_ENABLED=1
AUTH_API_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
EVENTING_API_CORS_ENABLED=1
EVENTING_API_CORS_ALLOWED_ORIGINS=
NOTIFICATION_API_CORS_ENABLED=1
NOTIFICATION_API_CORS_ALLOWED_ORIGINS=
OBSERVABILITY_API_CORS_ENABLED=1
OBSERVABILITY_API_CORS_ALLOWED_ORIGINS=

# ------------------------------------
# DOCUMENTATION
# ------------------------------------
DOCS_PT_PORT=8080
DOCS_EN_PORT=8081
DOCS_PT_PUBLIC_URL=
DOCS_EN_PUBLIC_URL=

# ------------------------------------
# PLATFORM SERVICES
# ------------------------------------
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=
LOKI_URL=http://localhost:3100
LOKI_READY_URL=http://localhost:3100/ready
LOKI_PORT=3100
GRAFANA_URL=http://localhost:3000
GRAFANA_HEALTH_URL=http://localhost:3000/api/health
GRAFANA_PORT=3000
SENTRY_DSN=
