{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlascore.local/contracts/auth-core/introspection/request.v1.schema.json",
  "title": "Auth/Core Introspection Request v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "required_permission": {
      "oneOf": [
        {
          "$ref": "#/$defs/permission"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "action"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100
        },
        "action": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50
        }
      }
    }
  }
}
