{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlascore.local/contracts/auth-core/introspection/response.v1.schema.json",
  "title": "Auth/Core Introspection Response v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "active",
    "allowed",
    "user",
    "permissions"
  ],
  "properties": {
    "active": {
      "type": "boolean"
    },
    "allowed": {
      "type": "boolean"
    },
    "user": {
      "$ref": "#/$defs/user"
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/permission"
      }
    },
    "required_permission": {
      "oneOf": [
        {
          "$ref": "#/$defs/permission"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "action"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100
        },
        "action": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50
        }
      }
    },
    "user": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "email",
        "is_active",
        "is_superuser",
        "token_version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "is_active": {
          "type": "boolean"
        },
        "is_superuser": {
          "type": "boolean"
        },
        "token_version": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
