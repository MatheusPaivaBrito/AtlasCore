{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlascore.local/contracts/core-notification/slack-delivery/request.v1.schema.json",
  "title": "Core Notification Slack Delivery Request v1",
  "type": "object",
  "required": ["message"],
  "additionalProperties": false,
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "channel": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 120
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata": {
      "type": "object"
    }
  }
}
